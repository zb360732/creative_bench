# Copy to `.env` (same folder) or repo root `.env`, then fill your real keys.
# Keys are loaded by `evalscope/run/run_from_models_json.py`.

# Shared fallback for entries whose `api_key` is "YOUR_API_KEY"
EVALSCOPE_API_KEY=sk-xxxx

# Or set per-model keys and reference them in models.json with:
#   "api_key": "${QWEN8B_API_KEY}"
#   "api_key_env": "QWEN8B_API_KEY"
QWEN8B_API_KEY=sk-xxxx
QWEN72B_API_KEY=sk-xxxx
QWEN_EMBEDDING_API_KEY=sk-xxxx
